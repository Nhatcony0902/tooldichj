# t1k-extended-multimodal — environment template
# Copy to .env (gitignored) and fill in. Resolution hierarchy: process env >
# project .claude/.env > user ~/.claude/.env (see scripts/check_setup.py).

# Required for native Gemini API (analyze/transcribe/extract/generate/video)
GEMINI_API_KEY=your_gemini_key_here          # https://aistudio.google.com/apikey
# Optional key rotation (add more numbered keys)
# GEMINI_API_KEY_2=second_key
# GEMINI_API_KEY_3=third_key

# Optional — MiniMax (image/video/speech/music generation)
# MINIMAX_API_KEY=your_minimax_key_here

# Optional — OpenAI-compatible backend for analyze (vision) + generate (image).
# When set, those two tasks route through ${GEMINI_OPENAI_BASE_URL}/v1/chat/completions
# and GEMINI_API_KEY is used as the bearer token. Audio/video/transcribe stay native.
#   LiteLLM proxy (vision + image-gen):
# GEMINI_OPENAI_BASE_URL=https://litellm.athena.tools
#   model-router CCS (vision only; set GEMINI_API_KEY="$(gh auth token)"):
# GEMINI_OPENAI_BASE_URL=https://ccs.the1studio.org/api/provider/kimi

# Optional model overrides
# MULTIMODAL_MODEL=gemini-2.5-flash            # analyze/transcribe/extract default
# IMAGE_GEN_MODEL=gemini-3.1-flash-image-preview
