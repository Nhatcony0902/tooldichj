# PostgreSQL connection (matches docker-compose.yml's "db" service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/tooldichj

# Server port
PORT=3001

# Secret used to sign JWT access tokens
JWT_SECRET=replace_with_a_long_random_secret

# SMTP config for sending email-verification OTP codes (e.g. Gmail SMTP, Mailtrap, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM="ToolDichJ <no-reply@tooldichj.com>"

# Google Gemini API key used by TranslationService (Gen AI SDK).
# If unset, the backend falls back to a mock translator (dev-friendly, not for production).
GEMINI_API_KEY=replace_with_your_gemini_api_key

# VietQR static QR config for billing/top-up (Phase 5 — no merchant SDK required).
BANK_BIN=replace_with_bank_bin_code
BANK_ACCOUNT_NO=replace_with_bank_account_number
BANK_ACCOUNT_NAME=REPLACE_WITH_ACCOUNT_HOLDER_NAME
VIETQR_TEMPLATE=compact2

# Local filesystem root for uploaded/processed video assets (Phase 1 upload pipeline).
STORAGE_ROOT_DIR=./storage

# Redis connection for BullMQ job queue (Phase 2 — video translation pipeline worker).
REDIS_HOST=localhost
REDIS_PORT=6379
