// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TranslationCache {
  id             Int      @id @default(autoincrement())
  textHash       String   // Hash SHA256 của sourceText để lập chỉ mục nhanh
  sourceText     String
  translatedText String
  sourceLang     String
  targetLang     String
  createdAt      DateTime @default(now())

  @@unique([textHash, sourceLang, targetLang])
  @@index([textHash])
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  password         String
  name             String     // Họ và tên người dùng
  phone            String?    // Số điện thoại (tùy chọn)
  avatarUrl        String?    // Ảnh đại diện (tùy chọn)
  role             String     @default("USER") // USER, VIP, ADMIN
  credits          Int        @default(100) // Tặng 100 credits khi đăng ký mới
  mfaEnabled       Boolean    @default(false)
  mfaSecret        String?
  mfaPendingSecret String?
  emailVerified           Boolean   @default(false)
  emailVerifyOtp          String?
  emailVerifyOtpExpiresAt DateTime?
  emailVerifyLastSentAt   DateTime?
  emailVerifyAttempts     Int       @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  jobs             VideoJob[]
  topupRequests    CreditTopupRequest[]
  passwordResetOtp          String?
  passwordResetOtpExpiresAt DateTime?
}

model VideoJob {
  id              String   @id @default(uuid())
  fileName        String
  inputStorageKey String?
  status          String   // PENDING, PROCESSING, COMPLETED, FAILED
  progress        Int      @default(0)
  stepDescription String   @default("Đang chờ...")
  targetLang      String   @default("vi")
  outputMode      String   @default("burn") // burn | srt
  errorMessage    String?
  subtitlesUrl    String?
  outputVideoUrl  String?
  outputAudioUrl  String?
  transcript      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TtsCache {
  id        Int      @id @default(autoincrement())
  textHash  String
  voice     String
  lang      String
  audioKey  String
  createdAt DateTime @default(now())

  @@unique([textHash, voice, lang])
  @@index([textHash])
}

model CreditTopupRequest {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  orderCode   String   @unique
  status      String   @default("PENDING") // PENDING, CONFIRMED, REJECTED
  note        String?
  confirmedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
