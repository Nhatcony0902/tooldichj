// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TranslationHistory {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceText     String
  translatedText String
  sourceLang     String // resolved code, never the literal "auto"
  targetLang     String
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

model TranslationCache {
  id             Int      @id @default(autoincrement())
  textHash       String // Hash SHA256 của sourceText để lập chỉ mục nhanh
  sourceText     String
  translatedText String
  sourceLang     String
  targetLang     String
  createdAt      DateTime @default(now())

  @@unique([textHash, sourceLang, targetLang])
  @@index([textHash])
}

model User {
  id                        String               @id @default(uuid())
  email                     String               @unique
  password                  String
  name                      String // Họ và tên người dùng
  phone                     String? // Số điện thoại (tùy chọn)
  avatarUrl                 String? // Ảnh đại diện (tùy chọn)
  role                      String               @default("USER") // USER, VIP, ADMIN
  credits                   Int                  @default(100) // Tặng 100 credits khi đăng ký mới
  mfaEnabled                Boolean              @default(false)
  mfaSecret                 String?
  mfaPendingSecret          String?
  emailVerified             Boolean              @default(false)
  emailVerifyOtp            String?
  emailVerifyOtpExpiresAt   DateTime?
  emailVerifyLastSentAt     DateTime?
  emailVerifyAttempts       Int                  @default(0)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  jobs                      VideoJob[]
  topupRequests             CreditTopupRequest[]
  historyEntries            TranslationHistory[]
  passwordResetOtp          String?
  passwordResetOtpExpiresAt DateTime?
  passwordResetLastSentAt   DateTime?
  passwordResetAttempts     Int                  @default(0)
  preferredVoiceId          String?
}

model VideoJob {
  id              String   @id @default(uuid())
  fileName        String
  inputStorageKey String?
  status          String // PENDING, PROCESSING, AWAITING_REVIEW, COMPLETED, FAILED, CANCELLED
  progress        Int      @default(0)
  stepDescription String   @default("Đang chờ...")
  targetLang      String   @default("vi")
  outputMode      String   @default("burn") // srt | burn
  removeSourceSubs Boolean  @default(false)
  errorMessage     String?
  untranslatedSegmentCount Int     @default(0) // segments left as source text after retries exhausted (B1)
  blurStatus               String? // null=not requested | 'applied' | 'skipped_no_subtitle' | 'skipped_error' (B2)
  dubStatus                String? // null=not requested | 'applied' | 'skipped_no_speech' (all segments dropped as Whisper hallucinations)
  subtitlesUrl    String?
  outputVideoUrl  String?
  outputAudioUrl  String?
  transcript      Json?
  translatedSegments Json?   // [{ start, end, text, translatedText }] — persisted at AWAITING_REVIEW for the review/edit checkpoint
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TtsCache {
  id              Int      @id @default(autoincrement())
  textHash        String
  voiceId         String
  audioStorageKey String
  createdAt       DateTime @default(now())

  @@unique([textHash, voiceId])
  @@index([textHash])
}

model CreditTopupRequest {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  orderCode   String   @unique
  status      String   @default("PENDING") // PENDING, CONFIRMED, REJECTED
  note        String?
  confirmedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
